<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinator_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <!-- Column Setup Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_setup_columns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Setup Columns"
                app:icon="@drawable/ic_settings"
                app:cornerRadius="12dp"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- Typography Controls Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardCornerRadius="12dp"
                app:contentPadding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Formatting"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Font Size -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Font Size"
                            android:textAppearance="?attr/textAppearanceBodySmall" />

                        <TextView
                            android:id="@+id/font_size_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14sp"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/colorPrimary" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekbar_font_size"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:min="8"
                        android:max="28"
                        android:progress="14"
                        android:layout_marginBottom="12dp" />

                    <!-- Letter Spacing -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Letter Spacing"
                            android:textAppearance="?attr/textAppearanceBodySmall" />

                        <TextView
                            android:id="@+id/letter_spacing_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0em"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/colorPrimary" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekbar_letter_spacing"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:min="0"
                        android:max="50"
                        android:progress="0"
                        android:layout_marginBottom="12dp" />

                    <!-- Font Styling (Bold/Italic) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <CheckBox
                            android:id="@+id/check_bold"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Bold"
                            android:textStyle="bold" />

                        <CheckBox
                            android:id="@+id/check_italic"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Italic"
                            android:textStyle="italic" />
                    </LinearLayout>

                    <!-- Row Padding -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Row Padding"
                            android:textAppearance="?attr/textAppearanceBodySmall" />

                        <TextView
                            android:id="@+id/row_padding_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12dp"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/colorPrimary" />
                    </LinearLayout>

                        <SeekBar
                            android:id="@+id/seekbar_row_padding"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:min="4"
                            android:max="32"
                            android:progress="12" />

                        <!-- Column Width Control -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="Selected Column Width"
                                android:textAppearance="?attr/textAppearanceBodySmall" />

                            <TextView
                                android:id="@+id/column_width_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:textColor="?attr/colorPrimary" />
                        </LinearLayout>

                        <SeekBar
                            android:id="@+id/seekbar_column_width"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:min="10"
                            android:max="300"
                            android:enabled="false" />

                        <!-- Theme Selector -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Theme"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:layout_marginEnd="16dp" />

                            <ImageView
                                android:id="@+id/theme_teal"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/circle_teal"
                                android:contentDescription="Teal theme" />

                            <ImageView
                                android:id="@+id/theme_blue"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/circle_blue"
                                android:contentDescription="Blue theme" />

                            <ImageView
                                android:id="@+id/theme_warm"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/circle_warm"
                                android:contentDescription="Warm theme" />

                            <ImageView
                                android:id="@+id/theme_gray"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/circle_gray"
                                android:contentDescription="Gray theme" />

                        </LinearLayout>

                        <!-- Auto Sr. No Toggle -->
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_auto_sr_no"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Auto Sr. No"
                            android:layout_marginTop="8dp"
                            android:textAppearance="?attr/textAppearanceBodySmall" />

                    </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Preset Chip Group -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_current_preset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Save Current"
                    app:icon="@drawable/ic_add"
                    app:cornerRadius="12dp"
                    android:layout_marginEnd="12dp"
                    style="@style/Widget.Material3.Button.TonalButton" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_presets"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true" />

                </HorizontalScrollView>
            </LinearLayout>

            <!-- Rate List Preview -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/preview_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:id="@+id/rate_list_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/white">

                    <!-- Global Title -->
                    <EditText
                        android:id="@+id/et_rate_list_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Meher Cables Rate List"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textAlignment="center"
                        android:gravity="center"
                        android:padding="12dp"
                        android:background="@android:color/transparent"
                        android:inputType="text"
                        android:maxLines="1"
                        android:importantForAutofill="no" />
                    <TextView
                        android:id="@+id/tv_a4_warning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="A4 size full or cannot be used for print"
                        android:textColor="?attr/colorError"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:visibility="gone"
                        android:background="#FFCDD2"
                        android:gravity="center" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fillViewport="true">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Dynamic Header Row (built programmatically) -->
                    <LinearLayout
                        android:id="@+id/header_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:background="#E0F2F1" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#006666" />

                    <!-- RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rate_list_recycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:minHeight="100dp" />

                            <!-- Empty State Message -->
                            <TextView
                                android:id="@+id/empty_message"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="No items in list. Add some using the + button."
                                android:textAlignment="center"
                                android:padding="32dp"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:visibility="gone" />

                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Export Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_export_pdf"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Download PDF"
                    app:icon="@drawable/ic_pdf"
                    app:cornerRadius="12dp"
                    style="@style/Widget.Material3.Button" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_export_png"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Download PNG"
                    app:icon="@drawable/ic_image"
                    app:cornerRadius="12dp"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>


</androidx.coordinatorlayout.widget.CoordinatorLayout>
